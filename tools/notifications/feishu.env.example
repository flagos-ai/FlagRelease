# 飞书自定义机器人 Webhook。请复制到仓库外的安全位置后 source，切勿提交真实地址。
export FEISHU_WEBHOOK_URL='https://open.feishu.cn/open-apis/bot/v2/hook/REPLACE_ME'

# auto: 配置了 Webhook 即发送；0/false/off: 全部禁用。
export FLAGOS_FEISHU_ENABLED='auto'

# 可选：只启用指定事件。
# task_start=任务开始，result_summary=逐模型结果汇总，task_end=任务结束/最终结果汇总。
export FLAGOS_FEISHU_NOTIFY_EVENTS='task_start,result_summary,task_end'

# 可选：interactive（默认）、post、text。
export FLAGOS_FEISHU_MESSAGE_FORMAT='interactive'

# 可选：显式指定当前机器 GPU 厂商；优先级高于 context 和宿主机探测。
# 例如 metax、hygon、nvidia、huawei、cambricon、mthreads、kunlunxin、tianshu。
export FLAGOS_VENDOR=''

# 独立 run_pipeline.sh 是否发送单模型开始/结束通知，默认 1。
# run_batch.sh 会为嵌套流水线自动设为 0，避免重复通知。
export FLAGOS_FEISHU_PIPELINE_NOTIFY='1'

# 批次卡片模型明细表最多展示行数；超出后保留关键行并注明省略数量。
export FLAGOS_FEISHU_TABLE_MAX_ROWS='20'
